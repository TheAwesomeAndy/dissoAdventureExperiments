	keywords = {Electrocardiography, Monitoring, Support vector machines, Biomedical monitoring, electrocardiogram, Skin, Stress, Stress measurement, heart rate, biophysiological stress response, electromyograph, respiratory rate, sensitivity analysis, skin conduction, Stress monitoring},
	pages = {93567--93579},
