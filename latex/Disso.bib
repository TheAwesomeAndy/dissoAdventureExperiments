Cg\_type: Nature Research Journals
Number: 6965
Primary\_atype: Research
Publisher: Nature Publishing Group},
	keywords = {Humanities and Social Sciences, multidisciplinary, Science},
	pages = {442--446},
	file = {Snapshot:C\:\\Users\\alane\\Zotero\\storage\\7LDXRZED\\nature02116.html:text/html;Wehr_Zador_2003_Balanced inhibition underlies tuning and sharpens spike timing in auditory.pdf:C\:\\Users\\alane\\Zotero\\storage\\VVMA3M49\\Wehr_Zador_2003_Balanced inhibition underlies tuning and sharpens spike timing in auditory.pdf:application/pdf},
