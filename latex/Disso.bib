@article{roy_online_2016,
	title = {An {Online} {Structural} {Plasticity} {Rule} for {Generating} {Better} {Reservoirs}},
	volume = {28},
	issn = {0899-7667},
	url = {https://doi.org/10.1162/NECO_a_00886},
	doi = {10.1162/NECO_a_00886},
	abstract = {In this letter, we propose a novel neuro-inspired low-resolution online unsupervised learning rule to train the reservoir or liquid of liquid state machines. The liquid is a sparsely interconnected huge recurrent network of spiking neurons. The proposed learning rule is inspired from structural plasticity and trains the liquid through formating and eliminating synaptic connections. Hence, the learning involves rewiring of the reservoir connections similar to structural plasticity observed in biological neural networks. The network connections can be stored as a connection matrix and updated in memory by using address event representation (AER) protocols, which are generally employed in neuromorphic systems. On investigating the pairwise separation property, we find that trained liquids provide 1.36  0.18 times more interclass separation while retaining similar intraclass separation as compared to random liquids. Moreover, analysis of the linear separation property reveals that trained liquids are 2.05  0.27 times better than random liquids. Furthermore, we show that our liquids are able to retain the generalization ability and generality of random liquids. A memory analysis shows that trained liquids have 83.67  5.79 ms longer fading memory than random liquids, which have shown 92.8  5.03 ms fading memory for a particular type of spike train inputs. We also throw some light on the dynamics of the evolution of recurrent connections within the liquid. Moreover, compared to separation-driven synaptic modification', a recently proposed algorithm for iteratively refining reservoirs, our learning rule provides 9.30\%, 15.21\%, and 12.52\% more liquid separations and 2.8\%, 9.1\%, and 7.9\% better classification accuracies for 4, 8, and 12 class pattern recognition tasks, respectively.},
	number = {11},
	urldate = {2021-12-15},
	journal = {Neural Computation},
	author = {Roy, Subhrajit and Basu, Arindam},
	month = nov,
	year = {2016},
	pages = {2557--2584},
	file = {Roy_Basu_2016_An Online Structural Plasticity Rule for Generating Better Reservoirs.pdf:C\:\\Users\\alane\\Zotero\\storage\\9A55QBGH\\Roy_Basu_2016_An Online Structural Plasticity Rule for Generating Better Reservoirs.pdf:application/pdf;Snapshot:C\:\\Users\\alane\\Zotero\\storage\\RT88AKLV\\An-Online-Structural-Plasticity-Rule-for.html:text/html},
}

@article{weddell_reservoir_2021,
	title = {Reservoir computing approaches to microsleep detection},
	volume = {18},
	issn = {1741-2552},
	url = {https://doi.org/10.1088/1741-2552/abcb7f},
	doi = {10.1088/1741-2552/abcb7f},
	abstract = {Objective. The detection of microsleeps in a wide range of professionals working in high-risk occupations is very important to workplace safety. A microsleep classifier is presented that employs a reservoir computing (RC) methodology. Specifically, echo state networks (ESN) are used to enhance previous benchmark performances on microsleep detection. Approach. A clustered design using a novel ESN-based leaky integrator is presented. The effectiveness of this design lies with the simplicity of using a fine-grained architecture, containing up to 8 neurons per cluster, to capture individualized state dynamics and achieve optimal performance. This is the first study to have implemented and evaluated EEG-based microsleep detection using RC models for the detection of microsleeps from the EEG. Main results. Microsleep state detection was achieved using a cascaded ESN classifier with leaky-integrator neurons employing 60 principal components from 544 power spectral features. This resulted in a leave-one-subject-out average detection in performance of φ = 0.51 ± 0.07 (mean ± SE), AUC− ROC = 0.88 ± 0.03, and AUC− PR = 0.44 ± 0.09. Significance. Although performance of EEG-based microsleep detection systems is still considered modest, this refined method achieved a new benchmark in microsleep detection.},
	language = {en},
	number = {4},
	urldate = {2021-12-15},
	journal = {Journal of Neural Engineering},
	author = {Weddell, Stephen J. and Ayyagari, Sudhanshu and Jones, Richard D.},
	month = mar,
	year = {2021},
	note = {Publisher: IOP Publishing},
	pages = {046021},
	file = {Weddell et al_2021_Reservoir computing approaches to microsleep detection.pdf:C\:\\Users\\alane\\Zotero\\storage\\ANL6EH8B\\Weddell et al_2021_Reservoir computing approaches to microsleep detection.pdf:application/pdf},
}

@inproceedings{tian_new_2021,
	address = {Daegu, Korea},
	title = {A {New} {Neuromorphic} {Computing} {Approach} for {Epileptic} {Seizure} {Prediction}},
	isbn = {978-1-72819-201-7},
	url = {https://ieeexplore.ieee.org/document/9401560/},
	doi = {10.1109/ISCAS51556.2021.9401560},
	abstract = {Several high specificity and sensitivity seizure prediction methods with convolutional neural networks (CNNs) are reported. However, CNNs are computationally expensive and power hungry. These inconveniences make CNN-based methods hard to be implemented on wearable devices. Motivated by the energy-efficient spiking neural networks (SNNs), a neuromorphic computing approach for seizure prediction is proposed in this work. This approach uses a designed gaussian random discrete encoder to generate spike sequences from the EEG samples and make predictions in a spiking convolutional neural network (Spiking-CNN) which combines the advantages of CNNs and SNNs. The experimental results show that the sensitivity, specificity and AUC can remain 95.1\%, 99.2\% and 0.912 respectively while the computation complexity is reduced by 98.58\% compared to CNN, indicating that the proposed Spiking-CNN is hardware friendly and of high precision.},
	language = {en},
	urldate = {2021-12-15},
	booktitle = {2021 {IEEE} {International} {Symposium} on {Circuits} and {Systems} ({ISCAS})},
	publisher = {IEEE},
