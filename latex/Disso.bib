@phdthesis{feng_fetal_2020,
	address = {United States -- New York},
	type = {Ph.{D}.},
	title = {Fetal {Heart} {Rate} {Analysis} with {Gaussian} {Processes}},
	copyright = {Database copyright ProQuest LLC; ProQuest does not claim copyright in the individual underlying works.},
	url = {https://search.proquest.com/docview/2449468014/abstract/DC5E37BEAE774AB5PQ/1},
	abstract = {Cardiotocography (CTG) comprises of fetal heart rate (FHR) and uterine activity (UA) monitoring during pregnancy. It is used in hospitals on a regular basis because FHR and UA tracings contain important information about fetal well-being. Despite the CTG’s long history of use (of almost 50 years), the benefits it brings to the daily practice remain unsatisfying.
The interpretation of FHR recordings is a highly intricate and complex task with high inter- and intra-variable evaluations among obstetricians, notwithstanding the availability of various clinical guidelines. The evaluation and interpretation of FHR recordings are also challenging for computerized systems for various reasons including the noisy nature of the recordings, high percentage of missing samples, high complexity, and the lack of ground truth.
In this thesis, we investigate FHR and UA signals with methodologies based on Gaussian processes (GPs), which are used for flexible Bayesian nonparametric probabilistic learning of functions and mappings. Specifically, we developed GP-based methods for tasks including recovering missing samples in FHR recordings, classification of FHR tracings, and clustering of FHR tracings. The experimental results indicate that the GP-based methods achieved better performance. To better understand the interaction between FHR and UA, we developed GP-based methods for causal discovery between FHR and UA signals. The results indicate that uterine activity affects fetal heart rates, which agrees with clinical studies.},
	language = {English},
	urldate = {2021-03-16},
	school = {State University of New York at Stony Brook},
	author = {Feng, Guanchao},
	year = {2020},
	note = {ISBN: 9798678110343},
	keywords = {Fetal heart rate, Cardiotocography, Causality, Convergent cross mapping, Guassian process, Uterine activity},
	file = {Full Text PDF:C\:\\Users\\alane\\Zotero\\storage\\KXI4K3AA\\Feng - 2020 - Fetal Heart Rate Analysis with Gaussian Processes.pdf:application/pdf},
