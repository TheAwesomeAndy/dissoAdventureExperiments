@article{hitron_spiking_2020,
	title = {Spiking {Neural} {Networks} {Through} the {Lens} of {Streaming} {Algorithms}},
	abstract = {We initiate the study of biologically-inspired spiking neural networks from the perspective of streaming algorithms. Like computers, human brains face memory limitations, which pose a signiﬁcant obstacle when processing large scale and dynamically changing data. In computer science, these challenges are captured by the well-known streaming model, which can be traced back to Munro and Paterson ‘78 and has had signiﬁcant impact in theory and beyond. In the classical streaming setting, one must compute a function f of a stream of updates S = \{u1, . . . , um\}, given restricted single-pass access to the stream. The primary complexity measure is the space used by the algorithm.},
	language = {en},
	author = {Hitron, Yael and Musco, Cameron and Parter, Merav},
	year = {2020},
