	pmid = {10884324},
	pmcid = {PMC6772338},
	keywords = {Action Potentials, Animals, Computer Simulation, Visual Perception, Artifacts, Cats, Entropy, Geniculate Bodies, Neurons, Afferent, Photic Stimulation, Poisson Distribution, Reaction Time, Thalamus, Visual Pathways},
	pages = {5392--5400},
}

@article{lichtsteiner_128times_2008,
