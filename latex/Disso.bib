	note = {ISSN: 2156-8111},
	keywords = {Videos, Face, Autism, Cameras, Magnetic heads, Variable speed drives},
	pages = {178--183},
	file = {IEEE Xplore Abstract Record:C\:\\Users\\alane\\Zotero\\storage\\SHFQFD5Z\\8273597.html:text/html},
}

