@techreport{ho_affective_2021,
	title = {Affective computing at the edge: {A} bibliometric analysis of the period 1995-2020},
	shorttitle = {Affective computing at the edge},
	url = {https://osf.io/hu54t/},
	abstract = {Affective computing is one of the most dynamic, interdisciplinary researched topics that draw on computer sciences, engineering, psychology, physiology, and neuroscience to computationally model, track, and classify emotions and affective states. This field is the foundation of the fast-growing USD 20 billion emotional A.I. industry that transforms the way we live and work. Its applications range from music playlists compiling algorithms, drowsiness-detecting car engine, tone-sensing via texts, or micro-targeting algorithms for political ads. We deploy bibliometric analysis on a dataset of 1,646 Web-of-Science-indexed academic articles from 1995 to 2020 to track the development of the field: its growth rate, major players, major collaborative networks, and thematic evolution. The annual growth rate of scientific production is 12.5\%. There is an exponential growth of scientific publications in this field, as the number of publication output in 2016-2020 alone far outstrips that in the previous 20 years (860 vs. 786). While the U.S. dominates the field both in research output and citation from 1995-2015, China emerges as a major player as research published by corresponding authors from China overtake the USA as most cited in 2016-2020. Surprisingly, Japan was missing in the top 10 countries measured by both output and citation. Our analysis also identifies two major collaborative networks: the “Asia Pacific cluster” of the USA., China, Singapore, Japan; the “European” cluster of Germany, the U.K., and the Netherlands. Finally, the thematic analysis reveals a growing academic interest in further fine-tuning computational techniques related to affective computing, as well as a decline of interest in using affective computing to detect and study mental illnesses such as depression and bipolar disorders. From these observations of the historical data, we speculate on the future trends of this dynamic research field.},
	urldate = {2021-05-28},
	institution = {OSF Preprints},
	author = {Ho, Manh-Tung and Nguyen, Hong-Kong T. and Vuong, Quan-Hoang},
	month = mar,
	year = {2021},
	doi = {10.31219/osf.io/hu54t},
	note = {type: article},
	keywords = {affective computing, bibliometric analysis, Communication, Communication Technology and New Media, Computational Engineering, emotional AI, Engineering, machine intelligence, Social and Behavioral Sciences, thematic evolution},
	file = {Full Text PDF:C\:\\Users\\alane\\Zotero\\storage\\MLXUMWEJ\\Ho et al. - 2021 - Affective computing at the edge A bibliometric an.pdf:application/pdf},
}

