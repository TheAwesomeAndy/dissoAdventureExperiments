	file = {Calvo_D'Mello_2010_Affect Detection.pdf:C\:\\Users\\alane\\Zotero\\storage\\PDTFZKU4\\Calvo_D'Mello_2010_Affect Detection.pdf:application/pdf;IEEE Xplore Abstract Record:C\:\\Users\\alane\\Zotero\\storage\\6SFJEIWL\\5520655.html:text/html},
