	keywords = {Machine learning, Sensors, Monitoring, Biomedical monitoring, Stress, Stress measurement, Diagnosis or assessment, Mental Well-being, Mood, Pervasive computing, Physiological Measures, Tools, Ubiquitous computing},
	pages = {1--1},
	file = {IEEE Xplore Abstract Record:C\:\\Users\\alane\\Zotero\\storage\\DZGUSALH\\9162435.html:text/html;Woodward et al. - 2020 - Beyond Mobile Apps a Survey of Technologies for M.pdf:C\:\\Users\\alane\\Zotero\\storage\\Z3ZWISZN\\Woodward et al. - 2020 - Beyond Mobile Apps a Survey of Technologies for M.pdf:application/pdf},
