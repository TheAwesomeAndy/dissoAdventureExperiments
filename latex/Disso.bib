	pages = {4--24},
	file = {Wu et al_2021_A Comprehensive Survey on Graph Neural Networks.pdf:C\:\\Users\\alane\\Zotero\\storage\\PRVGTTV8\\Wu et al_2021_A Comprehensive Survey on Graph Neural Networks.pdf:application/pdf},
