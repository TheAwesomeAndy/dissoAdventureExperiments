	pages = {1289--1292},
	file = {IEEE Xplore Abstract Record:C\:\\Users\\alane\\Zotero\\storage\\YYIBIIXP\\8659484.html:text/html;Matsumoto et al. - 2018 - XOR learning by spiking neural network with infrar.pdf:C\:\\Users\\alane\\Zotero\\storage\\CU44T5ZJ\\Matsumoto et al. - 2018 - XOR learning by spiking neural network with infrar.pdf:application/pdf},
