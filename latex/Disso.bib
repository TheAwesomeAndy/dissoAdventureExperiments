	keywords = {Brain modeling, Pattern recognition, pattern classification, Electrocardiography, EEG, Electroencephalography, Emotion classification, Emotion recognition, Physiology, Videos, Databases, Signal processing, affective computing, physiological signals, signal processing, Mood, affect schedules, mood, personality traits},
