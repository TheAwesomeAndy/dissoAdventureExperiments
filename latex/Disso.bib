	keywords = {SYSNEURO},
	pages = {1543--1548},
	file = {ScienceDirect Full Text PDF:C\:\\Users\\alane\\Zotero\\storage\\LT963CJS\\Jack et al. - 2009 - Cultural Confusions Show that Facial Expressions A.pdf:application/pdf},
}

