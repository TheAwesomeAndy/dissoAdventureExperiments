	file = {Hitron et al. - 2020 - Spiking Neural Networks Through the Lens of Stream.pdf:C\:\\Users\\alane\\Zotero\\storage\\BCDMDVLA\\Hitron et al. - 2020 - Spiking Neural Networks Through the Lens of Stream.pdf:application/pdf},
